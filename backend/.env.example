# ── AgroEase Backend Environment Variables ──────────
# Copy this to .env and fill your values

NODE_ENV=development
PORT=5000

# MongoDB Atlas (free at cloud.mongodb.com)
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/agroease?retryWrites=true&w=majority

# JWT Secret (change this to any long random string)
JWT_SECRET=agroease_him_2024_super_secure_jwt_secret_change_me

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Fast2SMS (free Indian SMS — fast2sms.com)
FAST2SMS_API_KEY=your_fast2sms_key_here

# Razorpay (razorpay.com — test keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Cloudinary (free image hosting — cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# OpenAI (for AI disease detection — platform.openai.com)
OPENAI_API_KEY=sk-your_openai_key

# Google Maps (Phase 2 — console.cloud.google.com)
GOOGLE_MAPS_API_KEY=your_google_maps_key
